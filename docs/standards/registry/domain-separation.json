{
  "registry_version": 1,
  "status": "local-pre-construction-registry",
  "scope": "Local labels and transcript field contracts for draft-hyprstream-privacypass-pqhybrid-00. This is not an IANA, MOQT, or Privacy Pass codepoint registry and allocates no wire values.",
  "canonicalization": {
    "encoding": "construction-selected deterministic binary encoding; this registry does not yet select CBOR, Cap'n Proto, TLS presentation language, or another wire encoding",
    "text": "UTF-8 NFC; no leading/trailing ASCII whitespace; ASCII lowercase only for enumerated identifiers",
    "integers": "unsigned, shortest form; reject negative, indefinite-length, duplicate-key, and non-canonical encodings",
    "bytes": "byte strings only; reject alternative text/base encodings in a binary field",
    "digest": "exact algorithm and length are construction-selected; an identifier and length are mandatory before production"
  },
  "labels": [
    {
      "id": "hs-pp-pqhybrid/challenge/v1",
      "purpose": "Binds a future issuance challenge to issuer, audience, accepted state, policy, and selected suite.",
      "owner_issue": "#1060",
      "status": "blocked-construction-selection",
      "fields": ["issuer_id", "audience", "suite_id", "accepted_state_digest", "accepted_state_epoch", "policy_generation", "expiry", "challenge_nonce"]
    },
    {
      "id": "hs-pp-pqhybrid/issuance/v1",
      "purpose": "Separates an anonymous issuance transcript from redemption and token binding.",
      "owner_issue": "#1060",
      "status": "blocked-construction-selection",
      "fields": ["challenge_digest", "issuance_request", "issuance_response"]
    },
    {
      "id": "hs-pp-pqhybrid/redemption/v1",
      "purpose": "Binds a one-use anonymous capability to its exact origin authorization context.",
      "owner_issue": "#1061",
      "status": "blocked-construction-selection",
      "fields": ["issuer_id", "audience", "suite_id", "accepted_state_digest", "accepted_state_epoch", "policy_generation", "redemption_context", "token_nonce", "expiry"]
    },
    {
      "id": "hs-pp-pqhybrid/binding/v1",
      "purpose": "Binds a redemption to a fresh proof-of-possession and HyKEM recipient without naming a holder DID.",
      "owner_issue": "#1061",
      "status": "blocked-construction-selection",
      "fields": ["redemption_digest", "carrier_profile", "session_transcript_digest", "operation", "resource_commitment", "pop_public_key", "hykem_recipient", "one_use_nonce"]
    },
    {
      "id": "hs-pp-pqhybrid/unary/v1",
      "purpose": "Binds anonymous authorization to canonical unary request and response-recipient fields.",
      "owner_issue": "#1063",
      "status": "specification-only",
      "fields": ["binding_digest", "service", "method", "request_digest", "request_id", "request_nonce", "response_hykem_recipient"]
    },
    {
      "id": "hs-pp-pqhybrid/moqt-control/v1",
      "purpose": "Binds encrypted ordinary application control Objects to an outer MOQT session while preserving relay opacity.",
      "owner_issue": "#726",
      "status": "specification-only",
      "fields": ["binding_digest", "moqt_session_transcript_digest", "operation", "namespace_commitment", "track_commitment", "group_or_epoch", "outer_admission_class"]
    },
    {
      "id": "hs-pp-pqhybrid/key-release/v1",
      "purpose": "Binds exact response, stream, or group key-package release to the verified capability and recipient.",
      "owner_issue": "#554/#555/#726",
      "status": "specification-only",
      "fields": ["binding_digest", "release_kind", "resource_commitment", "track_or_group", "epoch", "direction", "recipient_key_id", "expiry"]
    }
  ],
  "fields": {
    "issuer_id": {"type": "text", "min_bytes": 1, "max_bytes": 512, "canonical": "resolved accepted-current issuer identifier"},
    "audience": {"type": "text", "min_bytes": 1, "max_bytes": 512, "canonical": "origin identifier; no URL normalization is implicit"},
    "suite_id": {"type": "text", "min_bytes": 1, "max_bytes": 64, "canonical": "ASCII lowercase registry name; unknown rejects"},
    "accepted_state_digest": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "algorithm and exact size selected by accepted-current state profile"},
    "accepted_state_epoch": {"type": "uint", "minimum": 0, "maximum": 18446744073709551615, "canonical": "shortest unsigned integer"},
    "policy_generation": {"type": "uint", "minimum": 0, "maximum": 18446744073709551615, "canonical": "shortest unsigned integer"},
    "expiry": {"type": "uint", "minimum": 0, "maximum": 18446744073709551615, "canonical": "Unix seconds; origin defines accepted clock skew"},
    "challenge_nonce": {"type": "bytes", "min_bytes": 16, "max_bytes": 64, "canonical": "uniform random opaque bytes"},
    "challenge_digest": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "digest of canonical challenge encoding"},
    "issuance_request": {"type": "bytes", "min_bytes": 1, "max_bytes": 65536, "canonical": "construction-defined opaque canonical request"},
    "issuance_response": {"type": "bytes", "min_bytes": 1, "max_bytes": 65536, "canonical": "construction-defined opaque canonical response"},
    "redemption_context": {"type": "bytes", "min_bytes": 16, "max_bytes": 256, "canonical": "origin-generated opaque context"},
    "token_nonce": {"type": "bytes", "min_bytes": 16, "max_bytes": 64, "canonical": "one-use token identifier; never log raw token"},
    "redemption_digest": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "digest of canonical redemption encoding"},
    "carrier_profile": {"type": "text", "min_bytes": 1, "max_bytes": 64, "canonical": "ASCII lowercase; owned-hybrid-transport or standard-public-relay only"},
    "session_transcript_digest": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "digest of carrier handshake/session transcript"},
    "operation": {"type": "text", "min_bytes": 1, "max_bytes": 128, "canonical": "ASCII lowercase action identifier"},
    "resource_commitment": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "digest of canonical resource/action scope"},
    "pop_public_key": {"type": "bytes", "min_bytes": 32, "max_bytes": 8192, "canonical": "construction-selected fresh one-use public key encoding"},
    "hykem_recipient": {"type": "bytes", "min_bytes": 32, "max_bytes": 16384, "canonical": "accepted-current recipient material; no test-store fallback"},
    "one_use_nonce": {"type": "bytes", "min_bytes": 16, "max_bytes": 64, "canonical": "fresh random binding nonce"},
    "binding_digest": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "digest of canonical binding encoding"},
    "service": {"type": "text", "min_bytes": 1, "max_bytes": 256, "canonical": "exact service identifier"},
    "method": {"type": "text", "min_bytes": 1, "max_bytes": 256, "canonical": "exact method identifier"},
    "request_digest": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "digest of canonical request bytes"},
    "request_id": {"type": "uint", "minimum": 0, "maximum": 18446744073709551615, "canonical": "shortest unsigned integer"},
    "request_nonce": {"type": "bytes", "min_bytes": 16, "max_bytes": 64, "canonical": "fresh request nonce"},
    "response_hykem_recipient": {"type": "bytes", "min_bytes": 32, "max_bytes": 16384, "canonical": "fresh response recipient material"},
    "moqt_session_transcript_digest": {"type": "bytes", "min_bytes": 32, "max_bytes": 128, "canonical": "digest of exact MOQT session transcript"},
    "namespace_commitment": {"type": "bytes", "min_bytes": 16, "max_bytes": 128, "canonical": "digest/opaque canonical namespace commitment"},
    "track_commitment": {"type": "bytes", "min_bytes": 16, "max_bytes": 128, "canonical": "digest/opaque canonical track commitment"},
    "group_or_epoch": {"type": "uint", "minimum": 0, "maximum": 18446744073709551615, "canonical": "shortest unsigned integer"},
    "outer_admission_class": {"type": "text", "min_bytes": 1, "max_bytes": 64, "canonical": "ASCII lowercase coarse-admission result only"},
    "release_kind": {"type": "text", "min_bytes": 1, "max_bytes": 64, "canonical": "ASCII lowercase: unary-response, stream-epoch, or group-epoch"},
    "track_or_group": {"type": "bytes", "min_bytes": 16, "max_bytes": 128, "canonical": "opaque canonical identifier/commitment"},
    "epoch": {"type": "uint", "minimum": 0, "maximum": 18446744073709551615, "canonical": "shortest unsigned integer"},
    "direction": {"type": "text", "min_bytes": 1, "max_bytes": 32, "canonical": "ASCII lowercase direction identifier"},
    "recipient_key_id": {"type": "text", "min_bytes": 1, "max_bytes": 512, "canonical": "accepted-current purpose-separated recipient key identifier"}
  }
}
