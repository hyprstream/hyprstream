# Build artifacts
target/
dist/
**/*.rs.bk

# Git repository
.git/
.gitignore

# Archives and logs
*.tar.gz
*.log
*.tmp
temp/
tmp/

# Environment and secrets
.env
.env.*
*.pem
*.key

# Documentation (not needed in image)
*.md
!README.md
docs/

# CI/CD
.github/

# Development files
*.sh

# Test files
tests/
examples/
benches/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Package files
*.deb

# Cache directories
node_modules/
.cache/

# Rust specific
# NOTE: do NOT ignore Cargo.lock here. The release image build runs
# `cargo build --release --no-default-features --features otel,gittorrent,xet`
# and must honor the committed lock so duckdb/datafusion stay on one arrow major.
# (Historically this entry stripped the lock, letting duckdb float to arrow 58.)
*.profraw

# Config directories
config/
